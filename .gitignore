# Virtual environment
venv/
.venv/

# API Keys — 絕對不要提交（.env 與任何純文字 key 備份檔）
.env

# API Key 純文字備份 — 永遠不要提交這些！
# 若不小心 add 請立即執行 git rm --cached <file>
Alpha*KEY*.txt
Alpha*key*.txt
FRED*key*.txt
FRED*KEY*.txt
*API*KEY*.txt
*api*key*.txt
# 如需保留其他 .txt，請明確 !排除，例如：
# !README.txt

