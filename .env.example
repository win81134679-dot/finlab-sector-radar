# FinLab 板塊偵測系統 — Python 後端環境變數
# 複製此檔為 .env 並填入實際值

# ── 必要 ────────────────────────────────────────────────────────────────
FINLAB_API_TOKEN=          # FinLab 台股 API Token
FRED_API_KEY=              # 美聯儲 FRED API Key
ALPHA_VANTAGE_KEY=         # Alpha Vantage API Key（SOXX 代理）

# ── 選填：Discord 通知 ─────────────────────────────────────────────────
DISCORD_WEBHOOK_DAILY=     # 每日分析通知
DISCORD_WEBHOOK_ALERT=     # 強烈關注警報
DISCORD_WEBHOOK_MACRO=     # 宏觀環境變化通知
DISCORD_WEBHOOK_SYSTEM=    # 系統錯誤通知

# ── 選填：調參 ─────────────────────────────────────────────────────────
CACHE_EXPIRE_HOURS=24      # 快取過期小時數
RS_LOOKBACK_DAYS=60        # 相對強度回溯天數
